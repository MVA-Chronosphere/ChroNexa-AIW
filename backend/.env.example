# Backend Configuration

# LLM Provider Settings
LLM_PROVIDER=gpt  # Options: gpt, ollama
GPT_API_KEY=your_openai_api_key_here
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat-7b

# Knowledge Base Settings
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your_strapi_token_here
QA_DATABASE_URL=sqlite:///./qa_database.db

# Text-to-Speech Settings
TTS_PROVIDER=edge-tts  # Options: edge-tts, pyttsx3
TTS_VOICE=hi-IN  # Indian Hindi voice
TTS_ACCENT=indian

# Lip Sync Settings
RHUBARB_PATH=/usr/local/bin/rhubarb
AUDIO_SAMPLE_RATE=22050

# Server Settings
DEBUG=False
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
API_PORT=8000
API_HOST=0.0.0.0

# Database
DATABASE_URL=sqlite:///./chronexa.db

# Logging
LOG_LEVEL=INFO
